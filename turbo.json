{
  "$schema": "https://turborepo.com/schema.json",
  "globalPassThroughEnv": ["TMPDIR"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"],
      "env": ["FC_NUM_RUNS"],
      "outputs": ["coverage/**"]
    },
    "e2e": {
      "dependsOn": ["^build"]
    }
  }
}
